# MintSim Tapper — .env шаблон
# Скопировать в .env и заполнить

# Telegram Bot
BOT_TOKEN=your_bot_token_here

# TON
TON_API_KEY=your_tonapi_key_here
MS_COLLECTION_ADDRESS=your_mintsim_nft_collection_address

# База данных (SQLite для старта, Postgres для прода)
DATABASE_URL="file:./dev.db"

# CORS — URL фронтенда (Vercel)
FRONTEND_URL=https://your-app.vercel.app

# Adsgram
ADSGRAM_BLOCK_ID=your_block_id_from_adsgram_cabinet
